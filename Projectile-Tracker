"""Projectile Tracker by Group 5 for Dennis Moreno's EGR115 at ERAU Sping 2026"""
import math
import Projectile_Functions as pro12

launch_velocity, launch_height, launch_angle = pro12.projectile_setup()

if launch_velocity == "exit" or launch_height == "exit" or launch_angle == "exit":  # Check if the user wants to exit the program
    print("Exiting program...")
    exit()
elif launch_velocity != int(launch_velocity) or launch_height != int(launch_height) or launch_angle != int(launch_angle): #Check if inputs are valid
    print("Invalid input. Please enter numeric values for launch velocity, launch height, and launch angle.")
    exit()
else: #Continues Program if inputs are valid
    launch_velocity = float(launch_velocity) 
    launch_height = float(launch_height)
    launch_angle = float(launch_angle)

time_of_flight = pro12.time_of_flight(launch_velocity, launch_height, launch_angle)
horizontal_range = pro12.horizontal_range(launch_velocity, launch_angle, time_of_flight)
max_height = pro12.max_height(launch_velocity, launch_angle)

for i in range(0, int(horizontal_range) + 1): # Loop through x values from 0 to horizontal range
    x =  i
    y = pro12.nonlinear_trajectory(launch_angle, launch_velocity, x) # Calculate the corresponding y value using the nonlinear trajectory function
    plotpoints = [x,y] # Initialize an empty list to store the (x, y) coordinates of the projectile's trajectory
    plotpoints.append((x, y)) # Append the (x, y) coordinates to the plotpoints list

print(plotpoints) # Print the list of (x, y) coordinates for the projectile's trajectory


